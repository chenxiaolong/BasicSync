    <string name="pref_run_on_battery_name">Działa na zasilaniu bateryjnym</string>
    <string name="pref_run_on_battery_desc">Działaj, gdy urządzenie jest zasilane bateryjnie, a poziom naładowania baterii wynosi co najmniej %1$d%%. Syncthing zawsze działa po podłączeniu do zasilania.</string>
